<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sofia Farinati | Portfolio</title>
    <style>
        /* RESET & BASE STYLES */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Helvetica Neue', Arial, sans-serif;
        }

        body {
            background-color: #0f0f0f;
            color: #f0f0f0;
            overflow-x: hidden;
        }

        /* MODELLO IN MOVIMENTO (Sfondo) */
        .dynamic-bg-model {
            position: fixed;
            top: 20%;
            right: -10%;
            width: 50vw;
            height: 50vw;
            background: linear-gradient(45deg, #ff0055, #00eeff);
            border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
            filter: blur(80px);
            opacity: 0.4;
            z-index: -1;
            animation: morph 15s ease-in-out infinite alternate, spin 20s linear infinite;
        }

        @keyframes morph {
            0% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; }
            100% { border-radius: 70% 30% 50% 50% / 30% 30% 70% 70%; }
        }
        @keyframes spin {
            100% { transform: rotate(360deg); }
        }

        /* SCROLLING TESTO (Marquee) */
        .marquee-container {
            width: 100%;
            overflow: hidden;
            background: #f0f0f0;
            color: #0f0f0f;
            padding: 15px 0;
            position: fixed;
            top: 0;
            z-index: 100;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .marquee-content {
            display: inline-block;
            white-space: nowrap;
            animation: marquee 20s linear infinite;
        }
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* HERO SECTION */
        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 20px;
            margin-top: 50px;
        }
        .hero h1 {
            font-size: 4rem;
            margin-bottom: 10px;
            text-transform: uppercase;
        }
        .hero h2 {
            font-size: 1.5rem;
            font-weight: 300;
            color: #a0a0a0;
            margin-bottom: 40px;
        }
        .profile-photo {
            width: 250px;
            height: 250px;
            border-radius: 50%;
            background-color: #333;
            background-image: url('inserisci_qui_la_tua_foto.jpg'); /* INSERISCI LA TUA FOTO QUI */
            background-size: cover;
            background-position: center;
            border: 4px solid #fff;
            margin-bottom: 30px;
            transition: transform 0.3s ease;
        }
        .profile-photo:hover {
            transform: scale(1.05);
        }

        /* PROJECTS SECTION */
        .section-title {
            font-size: 3rem;
            text-align: center;
            margin: 100px 0 50px;
            text-transform: uppercase;
        }
        .project {
            max-width: 1200px;
            margin: 0 auto 150px auto;
            padding: 0 20px;
            opacity: 0;
            transform: translateY(50px);
            transition: all 0.8s ease-out;
        }
        .project.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .project-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            align-items: center;
        }
        @media(max-width: 768px) {
            .project-content { grid-template-columns: 1fr; }
        }
        .project-text h3 {
            font-size: 2.5rem;
            margin-bottom: 20px;
        }
        .project-text p {
            font-size: 1.1rem;
            line-height: 1.6;
            color: #cccccc;
            margin-bottom: 20px;
        }
        .project-images img {
            width: 100%;
            border-radius: 10px;
            margin-bottom: 20px;
            transition: transform 0.3s ease;
        }
        .project-images img:hover {
            transform: translateY(-10px);
        }

        /* DELIBARE - PALETTE INTERATTIVA */
        .palette-container {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }
        .palette-color {
            width: 60px;
            height: 100px;
            border-radius: 8px;
            cursor: pointer;
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .palette-color:hover {
            transform: translateY(-25px);
        }
        /* Colori estratti dalle tue immagini di Delibare */
        .c1 { background-color: #0d6e5a; } 
        .c2 { background-color: #d1d5b4; }
        .c3 { background-color: #e3a8b4; }
        .c4 { background-color: #1a4d43; }

        /* DOCUMENTARIO SECTION */
        .video-container {
            width: 100%;
            max-width: 1000px;
            margin: 0 auto;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }
        .video-container video {
            width: 100%;
            display: block;
        }

        /* ISOLA 86 PROCESS SECTION */
        .process-steps {
            background: #1a1a1a;
            padding: 30px;
            border-radius: 15px;
            margin-top: 30px;
            border-left: 4px solid #00eeff;
        }

        /* CONTACT SECTION */
        .contact {
            background-color: #000;
            padding: 100px 20px;
            text-align: center;
        }
        .contact h2 {
            font-size: 3rem;
            margin-bottom: 40px;
        }
        .contact-links {
            display: flex;
            flex-direction: column;
            gap: 20px;
            font-size: 1.5rem;
        }
        .contact-links a {
            color: #fff;
            text-decoration: none;
            transition: color 0.3s ease;
        }
        .contact-links a:hover {
            color: #00eeff;
        }
    </style>
</head>
<body>

    <div class="dynamic-bg-model"></div>

    <div class="marquee-container">
        <div class="marquee-content">
            SOFIA FARINATI - PORTFOLIO - GRAFICA E MEDIA DESIGN - ACCADEMIA MARIO VOLPATO - VERONA - SOFIA FARINATI - PORTFOLIO - GRAFICA E MEDIA DESIGN - ACCADEMIA MARIO VOLPATO - VERONA - 
        </div>
    </div>

    <section class="hero">
        <div class="profile-photo"></div>
        <h1>Sofia Farinati</h1>
        <h2>Studentessa di Grafica e Media Design <br> Accademia Mario Volpato, Verona</h2>
    </section>

    <h2 class="section-title">I Miei Progetti</h2>

    <section class="project">
        <div class="project-content">
            <div class="project-text">
                <h3>Delibare</h3>
                <p>Nasce dall’incontro tra un’esigenza e un sogno: educare al “bere bene” guidando le persone alla scoperta dei segreti costuditi della città.</p>
                <p>Siamo un bar itinerante che sfida la monotonia. <strong>TROVARCI FA PARTE DELL’ESPERIENZA.</strong></p>
                
                <div class="palette-container">
                    <div class="palette-color c1" title="Verde Smeraldo"></div>
                    <div class="palette-color c2" title="Crema"></div>
                    <div class="palette-color c3" title="Rosa Antico"></div>
                    <div class="palette-color c4" title="Verde Scuro"></div>
                </div>
            </div>
            <div class="project-images">
                <img src="Screenshot 2026-05-20 104935.jpg" alt="Delibare Logo su biglietto">
                <img src="Screenshot 2026-05-20 112118.jpg" alt="Delibare Biglietti da visita">
                <img src="Screenshot 2026-05-20 112137.jpg" alt="Delibare Maglietta">
            </div>
        </div>
    </section>

    <section class="project">
        <div class="project-content">
            <div class="project-images">
                <img src="Screenshot 2026-05-20 112323.jpg" alt="C2C Poster su strada">
                <img src="Screenshot 2026-05-20 112305.jpg" alt="C2C Festival Layout">
                <img src="Screenshot 2026-05-20 112226.png" alt="C2C Variazioni grafiche">
            </div>
            <div class="project-text">
                <h3>C2C Festival</h3>
                <p>Progetto di comunicazione visiva per l'edizione 2025 del C2C Festival (Torino/Europa). Esplorazione tipografica e di layout, declinata su formati digitali e per l'out-of-home advertising, in memoria di Sergio Ricciardone.</p>
            </div>
        </div>
    </section>

    <section class="project">
        <div class="project-content">
            <div class="project-text">
                <h3>Isola 86 - Eau de Parfum</h3>
                <p>Design di prodotto e renderizzazione 3D per il packaging del profumo Isola 86.</p>
                
                <div class="process-steps">
                    <h4>Il Processo Creativo</h4>
                    <br>
                    <p><strong>Fase 1:</strong> Ideazione della forma e modellazione 3D del flacone e del tappo, lavorando sulle rifrazioni del vetro.</p>
                    <p><strong>Fase 2:</strong> Studio dell'illuminazione (Lighting) per far risaltare il colore ambrato del liquido e creare riflessi caldi sullo sfondo.</p>
                    <p><strong>Fase 3:</strong> Applicazione delle texture e rendering finale in alta risoluzione.</p>
                    </div>
            </div>
            <div class="project-images">
                <img src="5.jpg" alt="Render Profumo Isola 86 Dettaglio">
                <img src="6.jpg" alt="Render Profumo Isola 86 Intero">
            </div>
        </div>
    </section>

    <section class="project">
        <h3 style="text-align: center; font-size: 2.5rem; margin-bottom: 30px;">Progetto Video: Documentario</h3>
        <p style="text-align: center; max-width: 800px; margin: 0 auto 40px auto; color: #ccc;">
            Lavoro di post-produzione, montaggio e finalizzazione. (Esportazione HD MP4).
        </p>
        <div class="video-container">
            <video controls poster="inserisci_un_frame_di_copertina.jpg">
                <source src="tuo_documentario.mp4" type="video/mp4">
                Il tuo browser non supporta il tag video.
            </video>
        </div>
    </section>

    <section class="contact" id="contact">
        <h2>Lavoriamo Insieme</h2>
        <div class="contact-links">
            <a href="tel:+393387500542">📞 338 7500542</a>
            <a href="mailto:tuaemail@esempio.com">✉️ Invia un'email</a>
            <a href="https://instagram.com/sofiafarinati" target="_blank">📱 @sofiafarinati</a>
        </div>
    </section>

    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.project').forEach((project) => {
            observer.observe(project);
        });
    </script>
</body>
</html>
